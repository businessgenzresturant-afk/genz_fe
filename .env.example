# API base URL used by frontend fetch calls.
# Keep empty to use same-origin paths (works with Vite proxy and production rewrites).
VITE_API_BASE_URL=

# Vite dev server proxy target for /api requests when VITE_API_BASE_URL is empty.
VITE_API_PROXY=http://127.0.0.1:5000

# Optional socket server URL override.
VITE_SOCKET_URL=http://127.0.0.1:5000
